    { "src": "/api/admin",               "dest": "/api/admin.js" },
    { "src": "/api/testimonials",        "dest": "/api/testimonials.js" },
    { "src": "/api/gallery",             "dest": "/api/gallery.js" },
    { "src": "/api/submit-testimonial",  "dest": "/api/submit-testimonial.js" },
